{
  "manifest_version": 3,
  "name": "Devil's Ace — Blackjack Practice Coach",
  "version": "1.0.0",
  "description": "Practice-only blackjack trainer: card-counting HUD + basic-strategy & live index-play coach. Not for real-money gambling.",
  "homepage_url": "https://github.com/atxgreene/Project_Devils_Ace",
  "permissions": ["activeTab", "scripting", "storage"],
  "background": { "service_worker": "background.js" },
  "commands": {
    "toggle-overlay": {
      "suggested_key": { "default": "Alt+Shift+C", "mac": "Alt+Shift+C" },
      "description": "Show / hide the Devil's Ace practice overlay"
    }
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Devil's Ace practice coach",
    "default_icon": { "16": "icons/icon16.png", "48": "icons/icon48.png", "128": "icons/icon128.png" }
  },
  "icons": { "16": "icons/icon16.png", "48": "icons/icon48.png", "128": "icons/icon128.png" }
}
